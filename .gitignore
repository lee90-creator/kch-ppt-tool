# --- Runtime data (may contain company documents / API keys) ---
data/
workspace/

# --- Build outputs & vendored wheels (regenerated by build/make_dist.py) ---
build/dist/
build/cache/

# --- Spike scratch & company-derived artifacts ---
spike/workspace/
spike/artifacts/

# --- Python caches ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
spike/RESULT.md

# --- Company-confidential style evidence (kept local, regenerable via tools/extract_style.py) ---
style/company_style_preview.md
style/company_style.full.json
